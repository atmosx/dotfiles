#!/usr/bin/env bash

# Author: Panagiotis (atmosx) Atmatzidis
# Last update: 2026-06-03
# Version: 7
# Description: Restic backup script for NAS, B2, and USB disk
# Usage: restic-backup --nas | --b2 | --usb

# Environment files:
# -----
# $ cat /usr/local/etc/restic/restic-nas-env
# export RESTIC_REPOSITORY="/mnt/some/dir/"
# export RESTIC_PASSWORD_FILE=/usr/local/etc/restic/restic-password
# $ cat /usr/local/etc/restic/restic-password
# abcd235

set -eo pipefail

# Check for the backup target flag
if [[ $# -ne 1 ]]; then
    echo "Usage: $0 --nas | --b2 | --usb"
    exit 1
fi

TARGET=$1

# Common backup dirs (shared across all targets)
COMMON_DIRS=("/etc"
             "/opt/photoprism"
             "/storage/backup"
             "/storage/photoprism/originals"
             "/storage/tiddlywiki"
             "/storage/gitdata"
             "/var/lib/gitea"
             "/storage/syncthing")

# Dirs only backed up to local targets (NAS/USB)
LOCAL_ONLY_DIRS=("/root" "/storage/videos")

# priorities hash
declare -A priorities=()
priorities["/etc"]=p3
priorities["/opt/photoprism"]=p1
priorities["/root"]=p2
priorities["/storage/backup"]=p2
priorities["/storage/photoprism/originals"]=p1
priorities["/storage/tiddlywiki"]=p1
priorities["/storage/videos"]=p1
priorities["/storage/syncthing"]=p1
priorities["/storage/gitdata"]=p2
priorities["/var/lib/gitea"]=p3

# exclude hash
# Values are relative to their source directory unless they start with /.
# Use newline-separated values for multiple exclusions.
declare -A exclude=()
exclude["/opt/photoprism"]=$'cache'

# Track failures across the entire run
FAILED=0

# Function to check if a directory is mounted
is_mounted() {
    mountpoint -q "$1"
}

# Function to mount a directory
mount_dir() {
    local mount_point=$1
    if is_mounted "$mount_point"; then
        logger -s -t restic-backup "$mount_point is already mounted."
    else
        logger -s -t restic-backup "Mounting $mount_point…"
        mount "$mount_point"
        if is_mounted "$mount_point"; then
            logger -s -t restic-backup "$mount_point mounted successfully."
        else
            logger -s -t restic-backup "Failed to mount $mount_point. Exiting."
            exit 1
        fi
    fi
}

# Function to unmount a directory
unmount_dir() {
    local mount_point=$1
    logger -s -t restic-backup "Unmounting $mount_point…"
    umount "$mount_point"
    if ! is_mounted "$mount_point"; then
        logger -s -t restic-backup "$mount_point unmounted successfully."
    else
        logger -s -t restic-backup "Failed to unmount $mount_point."
    fi
}

# Function to perform backup
perform_backup() {
    local env_file=$1
    local backup_dirs=("${!2}")
    local exclude_args=()
    local exclusion

    source "$env_file"
    logger -s -t restic-backup "Starting backup using environment file $env_file"

    for dir in "${backup_dirs[@]}"; do
        logger -s -t restic-backup "Backing up directory: $dir"
        cd "$dir" || { logger -s -t restic-backup "Failed to change directory to $dir. Skipping."; FAILED=1; continue; }

        exclude_args=()
        while IFS= read -r exclusion; do
            [[ -z $exclusion ]] && continue
            [[ $exclusion = /* ]] || exclusion="$dir/$exclusion"
            logger -s -t restic-backup "Excluding from $dir: $exclusion"
            exclude_args+=(--exclude "$exclusion")
        done <<< "${exclude[$dir]:-}"

        /usr/bin/restic backup --tag "${priorities[$dir]}" -q --skip-if-unchanged --no-scan "${exclude_args[@]}" . || {
            logger -s -t restic-backup "Backup FAILED for $dir"
            FAILED=1
            continue
        }
    done

    # Single prune pass after all backups are done
    logger -s -t restic-backup "Pruning old snapshots (daily 3, weekly 2, monthly 1)"
    /usr/bin/restic forget --keep-daily 3 --keep-weekly 2 --keep-monthly 1 --prune || {
        logger -s -t restic-backup "Prune FAILED"
        FAILED=1
    }
}

# Main script logic based on the target
case "$TARGET" in
    --nas)
        mount_point="/mnt/nas"
        env_file="/usr/local/etc/restic/restic-nas-env"
        backup_dirs=("${COMMON_DIRS[@]}" "${LOCAL_ONLY_DIRS[@]}")
        logger -s -t restic-backup "NAS backup launched"
        mount_dir "$mount_point"
        perform_backup "$env_file" backup_dirs[@]
        unmount_dir "$mount_point"
        ;;
    --b2)
        env_file="/usr/local/etc/restic/restic-b2-env"
        backup_dirs=("${COMMON_DIRS[@]}")
        logger -s -t restic-backup "Backblaze B2 backup launched"
        perform_backup "$env_file" backup_dirs[@]
        ;;
    --usb)
        mount_point="/mnt/usbdisk"
        env_file="/usr/local/etc/restic/restic-usb-env"
        backup_dirs=("${COMMON_DIRS[@]}" "${LOCAL_ONLY_DIRS[@]}")
        logger -s -t restic-backup "USB disk backup launched"
        mount_dir "$mount_point"
        perform_backup "$env_file" backup_dirs[@]
        unmount_dir "$mount_point"
        ;;
    *)
        echo "Invalid option. Use --nas, --b2, or --usb."
        exit 1
        ;;
esac

# Final backup status check
if [[ $FAILED -eq 0 ]]; then
    logger -s -t restic-backup "Backup process completed successfully for $TARGET."
else
    logger -s -t restic-backup "Backup process encountered errors for $TARGET."
fi

exit $FAILED
